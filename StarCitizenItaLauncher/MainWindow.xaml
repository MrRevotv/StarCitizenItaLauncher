<Window x:Class="StarCitizenItaLauncher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SC ITA Updater" Height="550" Width="750"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterScreen" MouseDown="Window_MouseDown"
        Icon="icona.ico">

    <Window.Resources>
        <Style TargetType="Button" x:Key="SciFiButton">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bordo" Background="{TemplateBinding Background}" CornerRadius="5" BorderThickness="1" BorderBrush="#44FFFFFF">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bordo" Property="Background" Value="#FF00D8FF"/>
                                <Setter Property="Foreground" Value="Black"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bordo" Property="Background" Value="#FF222222"/>
                                <Setter TargetName="bordo" Property="BorderBrush" Value="#FF444444"/>
                                <Setter Property="Foreground" Value="#FF666666"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ListBoxItem" x:Key="SciFiTab">
            <Setter Property="Background" Value="#FF1A222B"/>
            <Setter Property="Foreground" Value="#FF6B8296"/>
            <Setter Property="Padding" Value="20,8"/>
            <Setter Property="Margin" Value="5,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border Background="{TemplateBinding Background}" CornerRadius="3" BorderBrush="#FF00D8FF" BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#FF00D8FF"/>
                                <Setter Property="Foreground" Value="Black"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="IsSelected" Value="False"/>
                                </MultiTrigger.Conditions>
                                <Setter Property="Background" Value="#FF2A3A4A"/>
                                <Setter Property="Foreground" Value="White"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="#FF0C1014" CornerRadius="15" BorderBrush="#FF1E2832" BorderThickness="2" Margin="10">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" Color="Black" ShadowDepth="5" Opacity="0.5"/>
        </Border.Effect>

        <Grid RenderTransformOrigin="0.501,0.462">
            <!-- Barra del titolo -->
            <Grid Height="40" VerticalAlignment="Top">
                <TextBlock Text="REV.Tech//v2.0" Foreground="#FF00D8FF" VerticalAlignment="Center" Margin="20,0,0,0" FontWeight="Black"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,10,0">
                    <Button Content="? HELP" Width="70" Height="25" Background="#FFCC8800" Margin="0,0,10,0" Click="BtnHelp_Click" Style="{StaticResource SciFiButton}"/>
                    <Button Content="⚙ SETTINGS" Width="100" Height="25" Background="#FF1A222B" Margin="0,0,10,0" Click="BtnSettings_Click" Style="{StaticResource SciFiButton}"/>
                    <Button Content="✕" Width="30" Height="25" Background="#FFCC0000" Click="BtnClose_Click" Style="{StaticResource SciFiButton}"/>
                </StackPanel>
            </Grid>

            <Border Height="1" Background="#FF00D8FF" VerticalAlignment="Top" Margin="0,40,0,0" Opacity="0.3"/>

            <!-- Contenuto Centrale -->
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,20,0,60" RenderTransformOrigin="0.499,0.559">
                <TextBlock x:Name="TxtStatus" Text="INIZIALIZZAZIONE..." Foreground="White" FontSize="26" TextAlignment="Center" Margin="0,0,0,5" FontWeight="Black"/>
                <TextBlock x:Name="TxtGamePath" Text="Ricerca dati nel file system..." Foreground="#FF6B8296" FontSize="14" TextAlignment="Center" Margin="0,0,0,20"/>

                <ListBox x:Name="ListaCanali" Background="Transparent" BorderThickness="0" HorizontalAlignment="Center" Margin="0,0,0,30" Visibility="Hidden" SelectionChanged="ListaCanali_SelectionChanged" ItemContainerStyle="{StaticResource SciFiTab}">
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                </ListBox>

                <ProgressBar x:Name="PbDownload" Width="550" Height="8" Minimum="0" Maximum="100" Visibility="Hidden" Margin="0,0,0,30" Foreground="#FF00D8FF" Background="#FF1A222B" BorderThickness="0"/>

                <StackPanel Orientation="Vertical" HorizontalAlignment="Center" Margin="0,10">
                    <StackPanel Orientation="Horizontal" Margin="0,2">
                        <TextBlock Text="Ultima tua installazione: " Foreground="White" FontWeight="Bold"/>
                        <TextBlock x:Name="TxtDataLocale" Text="---" Foreground="LightGray"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,2">
                        <TextBlock Text="Ultima disponibile su Git: " Foreground="White" FontWeight="Bold"/>
                        <TextBlock x:Name="TxtDataOnline" Text="---" Foreground="Yellow"/>
                    </StackPanel>
                </StackPanel>

                <!-- GRUPPO BOTTONI PRINCIPALI -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <!-- Pulsante Principale (Installa/Gioca/Ripristina) -->
                    <Button x:Name="BtnAction" 
            Content="ATTENDERE" 
            Width="300" Height="60" 
            FontSize="20" 
            Background="#FF1A222B" 
            Click="BtnAction_Click" 
            IsEnabled="False" 
            Style="{StaticResource SciFiButton}"/>

                    <!-- Sottopannello verticale per i comandi di gestione file -->
                    <StackPanel Orientation="Vertical" Margin="10,0,0,0" VerticalAlignment="Center">

                        <!-- Pulsante Custom -->
                        <Button x:Name="BtnCustomLoad" 
                Content="📂 CUSTOM" 
                Width="120" Height="28" 
                FontSize="12" 
                Background="#FF8833FF" 
                Margin="0,0,0,4" 
                Click="BtnCustomLoad_Click" 
                Style="{StaticResource SciFiButton}" 
                Visibility="Collapsed"/>

                        <!-- Pulsante Rimuovi con stile emergenza -->
                        <Button x:Name="BtnRemove" 
        Content="🗑 RIMUOVI" 
        Width="120" Height="28" 
        FontSize="12" 
        Background="DarkRed" 
        Foreground="LightGoldenrodYellow" 
        Click="BtnRemove_Click" 
        Style="{StaticResource SciFiButton}" 
        Visibility="Collapsed"/>

                    </StackPanel>
                    <!-- Chiusura del sottopannello verticale -->
                </StackPanel>
                <!-- Chiusura del pannello orizzontale principale -->
            </StackPanel>

            <!-- Community Badge & Social Bar -->
            <StackPanel VerticalAlignment="Bottom">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,10">
                    <Image Source="community.png" Width="20" Height="20" Margin="0,0,8,0" RenderOptions.BitmapScalingMode="HighQuality"/>
                    <TextBlock Text="PROUDLY MADE BY THE COMMUNITY" Foreground="#FF6B8296" FontSize="11" FontWeight="Bold" VerticalAlignment="Center"/>
                </StackPanel>

                <Border Height="50" Background="#FF06080A" CornerRadius="0,0,13,13">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Button Width="130" Height="35" Background="#FF1A222B" Margin="10,0" Click="BtnYouTube_Click" Style="{StaticResource SciFiButton}">
                            <StackPanel Orientation="Horizontal">
                                <Image Source="youtube.png" Width="18" Height="18" Margin="0,0,8,0" RenderOptions.BitmapScalingMode="HighQuality"/>
                                <TextBlock Text="YOUTUBE" Foreground="#FFCC0000" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Width="130" Height="35" Background="#FF1A222B" Margin="10,0" Click="BtnDiscord_Click" Style="{StaticResource SciFiButton}">
                            <StackPanel Orientation="Horizontal">
                                <Image Source="discord.png" Width="18" Height="18" Margin="0,0,8,0" RenderOptions.BitmapScalingMode="HighQuality"/>
                                <TextBlock Text="DISCORD" Foreground="#FF5865F2" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Width="130" Height="35" Background="#FF1A222B" Margin="10,0" Click="BtnOrg_Click" Style="{StaticResource SciFiButton}">
                            <StackPanel Orientation="Horizontal">
                                <Image Source="org.png" Width="18" Height="18" Margin="0,0,8,0" RenderOptions.BitmapScalingMode="HighQuality"/>
                                <TextBlock Text="LSE ORG" Foreground="#FFAA6600" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- PANNELLO IMPOSTAZIONI -->
            <Grid x:Name="PanelImpostazioni" Visibility="Hidden" Background="#DD000000">
                <Border Background="#FF0C1014" Width="500" MinHeight="350" CornerRadius="10" BorderBrush="#FF00D8FF" BorderThickness="1" VerticalAlignment="Center" HorizontalAlignment="Center" Padding="20">
                    <StackPanel>
                        <TextBlock Text="IMPOSTAZIONI SISTEMA" Foreground="#FF00D8FF" FontSize="20" FontWeight="Black" Margin="0,0,0,20" HorizontalAlignment="Center"/>

                        <CheckBox x:Name="ChkAutoStart" Content="Avvia automaticamente all'avvio di Windows" Foreground="White" FontSize="14" Margin="0,5" Checked="ChkImpostazioni_Changed" Unchecked="ChkImpostazioni_Changed"/>
                        <CheckBox x:Name="ChkBackground" Content="Esegui in background in modalità silenziosa (non attivo in sviluppo)" Foreground="White" FontSize="14" Margin="0,5" Checked="ChkImpostazioni_Changed" Unchecked="ChkImpostazioni_Changed"/>

                        <!-- NUOVA CHECKBOX CUSTOM FILE -->
                        <CheckBox x:Name="ChkAllowCustom" Content="Abilita caricamento file traduzione custom" Foreground="#FF8833FF" FontSize="14" Margin="0,15,0,5" FontWeight="Bold" Checked="ChkImpostazioni_Changed" Unchecked="ChkImpostazioni_Changed"/>

                        <Border BorderBrush="#FF1E2832" BorderThickness="0,1,0,0" Margin="0,10,0,10" Padding="0,10,0,0">
                            <StackPanel>
                                <TextBlock Text="Percorso Installazione Star Citizen:" Foreground="#FF6B8296" FontSize="12" Margin="0,0,0,5"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="TxtImpostazioniPercorso" Text="C:\..." Foreground="White" Background="#FF1A222B" BorderBrush="#FF1E2832" Padding="5" IsReadOnly="True" Grid.Column="0" Margin="0,0,10,0"/>
                                    <Button Content="SFOGLIA" Width="80" Height="28" Background="#FF1A222B" Grid.Column="1" Click="BtnSfogliaCartella_Click" Style="{StaticResource SciFiButton}"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border BorderBrush="#FF1E2832" BorderThickness="0,1,0,0" Margin="0,5,0,10" Padding="0,10,0,0">
                            <StackPanel>
                                <TextBlock Text="Dettagli Applicazione:" Foreground="#FF6B8296" FontSize="12" Margin="0,0,0,5"/>
                                <TextBlock Text="Versione Installer: 2.0.1" Foreground="White" FontSize="12"/>
                                <TextBlock Text="Sviluppatore: MrRevo" Foreground="White" FontSize="12"/>
                            </StackPanel>
                        </Border>

                        <Button Content="CHIUDI" Width="150" Height="35" Background="#FF1A222B" Margin="0,10,0,0" Click="BtnChiudiSettings_Click" Style="{StaticResource SciFiButton}"/>
                    </StackPanel>
                </Border>
            </Grid>

        </Grid>
    </Border>
</Window>