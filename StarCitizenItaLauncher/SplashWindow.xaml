<Window x:Class="StarCitizenItaLauncher.SplashWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Caricamento..." Height="300" Width="500"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterScreen">

    <!-- Bordo con ombra luminosa (Glow Effect) -->
    <Border Background="#FF0C1014" CornerRadius="15" BorderBrush="#FF00D8FF" BorderThickness="1" Margin="20">
        <Border.Effect>
            <DropShadowEffect BlurRadius="15" Color="#FF00D8FF" ShadowDepth="0" Opacity="0.8"/>
        </Border.Effect>

        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
            <!-- TITOLO -->
            <TextBlock Text="   MrRevo&#x0a;        &amp;&#x0a;GattoMatto" Foreground="#FF00D8FF" FontSize="25" FontWeight="Black" FontFamily="Arial" HorizontalAlignment="Center" Margin="0,0,0,5">
                <TextBlock.Effect>
                    <DropShadowEffect BlurRadius="10" Color="#FF00D8FF" ShadowDepth="0"/>
                </TextBlock.Effect>
            </TextBlock>
            <TextBlock Text="LOCALIZZAZIONE ITALIANA v2.0" Foreground="White" FontSize="16" HorizontalAlignment="Center" Margin="0,0,0,40" Opacity="0.7"/>

            <!-- BARRA DI CARICAMENTO INFINITA -->
            <ProgressBar IsIndeterminate="True" Width="300" Height="4" Foreground="#FF00D8FF" Background="#FF1A222B" BorderThickness="0"/>

            <TextBlock Text="INIZIALIZZAZIONE SISTEMI REV.TECH..." Foreground="#FF00D8FF" FontSize="15" HorizontalAlignment="Center" Margin="0,15,0,0" Opacity="0.8"/>
        </StackPanel>
    </Border>
</Window>